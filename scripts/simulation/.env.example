# ─────────────────────────────────────────────────────────────────
# Ce fichier se remplit AUTOMATIQUEMENT avec :
#   npx vercel env pull scripts/simulation/.env
# Lance cette commande depuis la racine du projet. Tu n'as rien à
# copier-coller à la main.
# ─────────────────────────────────────────────────────────────────

# Supabase (déjà dans Vercel)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Voyage embeddings (déjà dans Vercel)
VOYAGE_API_KEY=

# Admin bypass (déjà dans Vercel sous le nom ADMIN_CODE)
ADMIN_CODE=

# Cron (déjà dans Vercel sous le nom CRON_SECRET)
CRON_SECRET=

# Target API — à renseigner toi-même (pas dans Vercel)
# Local  : http://localhost:3000   (si tu lances `vercel dev`)
# Prod   : https://voiceclone.vercel.app   (remplace par ton URL)
API_BASE_URL=http://localhost:3000
