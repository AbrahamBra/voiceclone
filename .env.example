# --- Required in prod ---

# Anthropic API (Claude)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Supabase (server-side)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Required for specific features ---

# Voyage embeddings (RAG chunks + entity embeddings). Without it, embedding features degrade gracefully.
VOYAGE_API_KEY=

# Vercel cron auth (Bearer token expected by /api/cron-consolidate)
CRON_SECRET=

# LinkedIn scraping (api/linkedin-scrape, create flow)
LINKDAPI_KEY=

# Admin override (auth bypass via code). Leave unset to disable.
ADMIN_CODE=

# --- Optional tuning ---

# Sentry error tracking (no-op if unset). To enable:
#   1. Create a project at sentry.io, copy DSN here (or in Vercel env vars)
#   2. Run `npm install @sentry/node` once
#   3. Redeploy — server-side 500s captured automatically via lib/api-errors.js
SENTRY_DSN=

# Inline consolidation in /api/chat for live demos. Default: off.
DEMO_MODE=false

# Default persona for knowledge lookups when none specified.
PERSONA=alex

# Silence lib/log.js output. Set to "1" to mute.
LOG_SILENT=

# --- Frontend (public, VITE_ prefix) ---

# Plausible Analytics (leave unset in local dev to disable tracking)
VITE_PLAUSIBLE_DOMAIN=
